{
  "expo": {
    "name": "Talab va Taklif Market",
    "slug": "talab-va-taklif-market",
    "version": "1.0.0",
    "icon": "./src/assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./src/assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "name": "Talab va Taklif Market",
      "shortName": "TalabTaklif",
      "favicon": "./src/assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "talab-va-taklif-market"
  }
}
