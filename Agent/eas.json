{
    "cli": {
        "version": ">= 5.9.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "store"
        },
        "preview": {
            "distribution": "store",
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            }
        },
        "production-apk": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "credentialsSource": "local"
            }
        }
    },
    "submit": {
        "production": {}
    }
}